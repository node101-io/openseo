{
  "name": "openseo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=!@openseo/contract",
    "dev:node": "pnpm --filter @openseo/contract dev",
    "deploy:local": "pnpm --filter @openseo/contract deploy:localhost",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
