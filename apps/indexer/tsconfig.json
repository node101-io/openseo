{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "noEmit": false, 
    "allowJs": true,
    "composite": true,
  },
  "include": ["src/**/*", "src/db/models"],
  "references": [
    { "path": "../../packages/zkproof" },
    { "path": "../../packages/contracts" },
    { "path": "../../packages/types" }
  ],
  "exclude": ["node_modules", "dist"]
}