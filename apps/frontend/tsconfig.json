{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "noEmit": true, 
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "composite": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*", "./app/*"] 
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules"]
}