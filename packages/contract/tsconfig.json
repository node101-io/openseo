{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",            
    "moduleResolution": "NodeNext",  
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./scripts",
    "./test",
    "./src",      
    "./hardhat.config.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "ts-node": {
    "esm": true  
  }
}