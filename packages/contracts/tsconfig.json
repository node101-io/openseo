{
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "commonjs",
    "target": "ES2022",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node", "mocha"],
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"],
    "composite": true,
  },
  "include": ["src/**/*", "scripts/**/*", "tests/**/*", "target/types/**/*"],
  "exclude": ["node_modules", "dist"]
}
